@prefix amt: <http://academic-meta-tool.xyz/vocab#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix ex: <http://github.com/leiza-scit/CAA2026-amt/> .

# AMT Ontology - Leonard Edition

amt:Concept rdfs:subClassOf rdfs:Class .
amt:Role rdfs:subClassOf rdf:Property .
amt:Axiom rdfs:subclassOf rdfs:Class .
amt:InferenceAxiom rdfs:subClassOf amt:Axiom .
amt:IntegrityAxiom rdfs:subClassOf amt:Axiom .
amt:RoleChainAxiom rdfs:subClassOf amt:InferenceAxiom .
amt:InverseAxiom rdfs:subClassOf amt:InferenceAxiom .
amt:DisjointAxiom rdfs:subClassOf amt:IntegrityAxiom .
amt:SelfDisjointAxiom rdfs:subClassOf amt:IntegrityAxiom .
amt:Logic rdfs:subClassOf rdfs:Class .
amt:LukasiewiczLogic rdf:type amt:Logic .
amt:ProductLogic rdf:type amt:Logic .
amt:GoedelLogic rdf:type amt:Logic .

# Potter Attribution Ontology

# concepts

ex:Feature rdf:type amt:Concept .
ex:Feature rdfs:label "Feature / Figure Type" .
ex:Feature amt:placeholder "Feature / Figure Type" .

ex:Potter rdf:type amt:Concept .
ex:Potter rdfs:label "Potter" .
ex:Potter amt:placeholder "Potter" .

ex:Sherd rdf:type amt:Concept .
ex:Sherd rdfs:label "Sherd" .
ex:Sherd amt:placeholder "Pot Sherd" .

ex:FindContext rdf:type amt:Concept .
ex:FindContext rdfs:label "Find Context" .
ex:FindContext amt:placeholder "Find Context" .

# roles

ex:FeatureAttributionDegree rdf:type amt:Role .
ex:FeatureAttributionDegree rdfs:label 'attribution' .
ex:FeatureAttributionDegree rdfs:domain ex:Feature .
ex:FeatureAttributionDegree rdfs:range ex:Potter .

ex:PotterAttributionDegree rdf:type amt:Role .
ex:PotterAttributionDegree rdfs:label 'attribution' .
ex:PotterAttributionDegree rdfs:domain ex:Potter .
ex:PotterAttributionDegree rdfs:range ex:Sherd .

ex:WeightedDatingDegree rdf:type amt:Role .
ex:WeightedDatingDegree rdfs:label 'weighted dating' .
ex:WeightedDatingDegree rdfs:domain ex:Sherd .
ex:WeightedDatingDegree rdfs:range ex:FindContext .

ex:FigureTypeRepertoireChoice rdf:type amt:Role .
ex:FigureTypeRepertoireChoice rdfs:label 'repertoire choice' .
ex:FigureTypeRepertoireChoice rdfs:domain ex:Feature .
ex:FigureTypeRepertoireChoice rdfs:range ex:Sherd .

ex:DatingWeight rdf:type amt:Role .
ex:DatingWeight rdfs:label 'dating weight' .
ex:DatingWeight rdfs:domain ex:Potter .
ex:DatingWeight rdfs:range ex:FindContext .

# RoleChainAxioms

ex:RCA0001 rdf:type amt:RoleChainAxiom .
ex:RCA0001 amt:antecedent1 ex:FeatureAttributionDegree .
ex:RCA0001 amt:antecedent2 ex:PotterAttributionDegree .
ex:RCA0001 amt:consequent ex:FigureTypeRepertoireChoice .
ex:RCA0001 amt:logic amt:ProductLogic .

ex:RCA0002 rdf:type amt:RoleChainAxiom .
ex:RCA0002 amt:antecedent1 ex:PotterAttributionDegree .
ex:RCA0002 amt:antecedent2 ex:WeightedDatingDegree .
ex:RCA0002 amt:consequent ex:DatingWeight .
ex:RCA0002 amt:logic amt:ProductLogic .

# Example Data Concepts

ex:Feature_Red amt:instanceOf ex:Feature. ex:Feature_Red rdfs:label 'Feature Red'.
ex:Feature_Blue amt:instanceOf ex:Feature. ex:Feature_Blue rdfs:label 'Feature Blue'.
ex:Feature_Green amt:instanceOf ex:Feature. ex:Feature_Green rdfs:label 'Feature Green'.
ex:Potter_A amt:instanceOf ex:Potter. ex:Potter_A rdfs:label 'Potter A'.
ex:Potter_B amt:instanceOf ex:Potter. ex:Potter_B rdfs:label 'Potter B'.
ex:Sherd_X amt:instanceOf ex:Sherd. ex:Sherd_X rdfs:label 'Sherd X'.
ex:Sherd_Z amt:instanceOf ex:Sherd. ex:Sherd_Z rdfs:label 'Sherd Z'.
ex:FindContext_I amt:instanceOf ex:FindContext. ex:FindContext_I rdfs:label 'Find Context I'.

# Example Data Roles

_:node01 rdf:subject ex:Feature_Red . _:node01 rdf:predicate ex:FeatureAttributionDegree . _:node01 rdf:object ex:Potter_A . _:node01 amt:weight 0.5 .
_:node02 rdf:subject ex:Potter_A . _:node02 rdf:predicate ex:PotterAttributionDegree . _:node02 rdf:object ex:Sherd_X . _:node02 amt:weight 0.6 .
_:node03 rdf:subject ex:Sherd_X . _:node03 rdf:predicate ex:WeightedDatingDegree . _:node03 rdf:object ex:FindContext_I . _:node03 amt:weight 0.51 .

_:node11 rdf:subject ex:Feature_Blue . _:node11 rdf:predicate ex:FeatureAttributionDegree . _:node11 rdf:object ex:Potter_B . _:node11 amt:weight 1.0 .
_:node21 rdf:subject ex:Feature_Green . _:node21 rdf:predicate ex:FeatureAttributionDegree . _:node21 rdf:object ex:Potter_B . _:node21 amt:weight 0.33 .
_:node12 rdf:subject ex:Potter_B . _:node12 rdf:predicate ex:PotterAttributionDegree . _:node12 rdf:object ex:Sherd_Z . _:node12 amt:weight 0.83 .
_:node13 rdf:subject ex:Sherd_Z . _:node13 rdf:predicate ex:WeightedDatingDegree . _:node13 rdf:object ex:FindContext_I . _:node13 amt:weight 0.6 .
